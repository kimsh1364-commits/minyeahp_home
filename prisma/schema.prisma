generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  character  Character?
  room       Room?
  sentFriendRequests     Friendship[] @relation("FriendshipSender")
  receivedFriendRequests Friendship[] @relation("FriendshipReceiver")
  messages   Message[]
}

model Character {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  skinTone  String @default("light")
  hairStyle String @default("short")
  hairColor String @default("black")
  eyeColor  String @default("brown")
  top       String @default("default_top")
  bottom    String @default("default_bottom")
  shoes     String @default("default_shoes")
  hat       String @default("none")
  accessory String @default("none")
}

model Room {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  wallpaper String @default("white")
  floor     String @default("wood")
  furniture String @default("[]")

  messages  Message[]
}

model Friendship {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     String           @default("pending")
  createdAt  DateTime         @default(now())

  sender   User @relation("FriendshipSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
}
